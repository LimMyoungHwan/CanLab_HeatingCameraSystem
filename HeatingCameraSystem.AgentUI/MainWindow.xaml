<Window x:Class="HeatingCameraSystem.AgentUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HeatingCameraSystem Agent" Height="680" Width="1040"
        Background="#1E1E1E">
    <Window.Resources>
        <SolidColorBrush x:Key="BorderBrush" Color="#3C3C3C"/>
        <SolidColorBrush x:Key="TextBrush" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#3D6FB4"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#232323"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="RowBackground" Value="#262626"/>
            <Setter Property="AlternatingRowBackground" Value="#2C2C2C"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#3C3C3C"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,3"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Bd" Background="#2A2A2A" BorderBrush="#3C3C3C" BorderThickness="1,1,1,0"
                                Margin="0,0,2,0" Padding="16,6" CornerRadius="4,4,0,0">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding HeaderText}"
                   Foreground="#E0E0E0" FontSize="16" FontWeight="SemiBold"
                   Margin="12,10"/>
        <TabControl Background="#1E1E1E" BorderBrush="#3C3C3C" Margin="6">

            <TabItem Header="Live">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Cameras}" Margin="6">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="6" Padding="6" CornerRadius="6"
                                        Background="#2A2A2A" BorderBrush="#3C3C3C" BorderThickness="1">
                                    <StackPanel Width="340">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="#F0F0F0" FontWeight="SemiBold" Margin="2,0,0,6"/>
                                        <Border Background="Black" Height="255">
                                            <Image Source="{Binding LiveImage}" Stretch="Uniform"/>
                                        </Border>
                                        <TextBlock Margin="2,6,0,0" Foreground="#B0B0B0">
                                            <Run Text="Status: "/>
                                            <Run Text="{Binding Status}"/>
                                        </TextBlock>
                                        <Button Content="Restart" Command="{Binding RestartCommand}"
                                                HorizontalAlignment="Left" Margin="2,8,0,0" Padding="12,3"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Data">
                <Grid Margin="6" DataContext="{Binding DataBrowser}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="360"/>
                    </Grid.ColumnDefinitions>
                    <DataGrid Grid.Column="0" ItemsSource="{Binding Captures}"
                              SelectedItem="{Binding Selected}" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time (UTC)" Width="150"
                                                Binding="{Binding TimestampUtc, StringFormat=yyyy-MM-dd HH:mm:ss}"/>
                            <DataGridTextColumn Header="Agent" Width="*" Binding="{Binding AgentId}"/>
                            <DataGridTextColumn Header="Cam" Width="46" Binding="{Binding CameraIndex}"/>
                            <DataGridTextColumn Header="Size" Width="80">
                                <DataGridTextColumn.Binding>
                                    <MultiBinding StringFormat="{}{0}×{1}">
                                        <Binding Path="Width"/>
                                        <Binding Path="Height"/>
                                    </MultiBinding>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Min" Width="60" Binding="{Binding Min}"/>
                            <DataGridTextColumn Header="Max" Width="60" Binding="{Binding Max}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <Border Background="Black" Height="255">
                            <Image Source="{Binding Preview}" Stretch="Uniform"/>
                        </Border>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Refresh" Command="{Binding RefreshCommand}"/>
                            <Button Content="Delete selected" Command="{Binding DeleteSelectedCommand}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="Retention (days):" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Text="{Binding RetentionDays}" Width="50"/>
                            <Button Content="Purge old" Command="{Binding PurgeCommand}" Margin="6,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding StatusText}" Foreground="#B0B0B0"
                                   Margin="0,8,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Logs">
                <DockPanel Margin="6" DataContext="{Binding Logs}">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Min level:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox ItemsSource="{Binding Levels}" SelectedItem="{Binding MinLevel}" Width="130"/>
                        <Button Content="Refresh" Command="{Binding RefreshCommand}" Margin="8,0,0,0"/>
                        <TextBlock Text="{Binding StatusText}" Foreground="#B0B0B0"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding Entries}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time (UTC)" Width="150"
                                                Binding="{Binding TimestampUtc, StringFormat=yyyy-MM-dd HH:mm:ss}"/>
                            <DataGridTextColumn Header="Level" Width="90" Binding="{Binding Level}"/>
                            <DataGridTextColumn Header="Message" Width="*" Binding="{Binding Message}"/>
                            <DataGridTextColumn Header="Exception" Width="220" Binding="{Binding Exception}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10" DataContext="{Binding Settings}">
                        <CheckBox Content="Simulation mode (fake cameras)"
                                  IsChecked="{Binding SimulationMode}" Margin="0,0,0,10"/>
                        <TextBlock Text="NATS URL"/>
                        <TextBox Text="{Binding NatsUrl}" Width="360" HorizontalAlignment="Left" Margin="0,2,0,8"/>
                        <TextBlock Text="Storage path (blank = default under config dir)"/>
                        <TextBox Text="{Binding StoragePath}" Width="360" HorizontalAlignment="Left" Margin="0,2,0,8"/>
                        <TextBlock Text="Heartbeat (seconds)"/>
                        <TextBox Text="{Binding HeartbeatSeconds}" Width="80" HorizontalAlignment="Left" Margin="0,2,0,8"/>
                        <TextBlock Text="Cameras" FontWeight="SemiBold" Margin="0,6,0,4"/>
                        <DataGrid ItemsSource="{Binding Cameras}" IsReadOnly="False" Height="180">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Agent Id" Width="*" Binding="{Binding AgentId}"/>
                                <DataGridTextColumn Header="OpenCV Index" Width="110" Binding="{Binding OpenCvIndex}"/>
                                <DataGridTextColumn Header="Alias" Width="*" Binding="{Binding Alias}"/>
                                <DataGridTemplateColumn Header="" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Remove"
                                                    Command="{Binding DataContext.RemoveCameraCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Add camera" Command="{Binding AddCameraCommand}"/>
                            <Button Content="Save" Command="{Binding SaveCommand}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding StatusText}" Foreground="#B0B0B0" Margin="0,8,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
