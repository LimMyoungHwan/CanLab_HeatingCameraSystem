<UserControl x:Class="HeatingCameraSystem.Master.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HeatingCameraSystem.Master.Views"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800" Background="White">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Control Panel -->
        <Border Grid.Row="0" Background="#f1f2f6" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Chamber PV: " FontWeight="Bold" FontSize="16" Foreground="#2f3542"/>
                    <TextBlock Text="{Binding CurrentTemperature, StringFormat={}{0:F1} °C}" FontSize="16" Margin="0,0,20,0" Foreground="#e15f41"/>
                    
                    <TextBlock Text="Humidity PV: " FontWeight="Bold" FontSize="16" Foreground="#2f3542"/>
                    <TextBlock Text="{Binding CurrentHumidity, StringFormat={}{0:F1} %}" FontSize="16" Foreground="#3dc1d3"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Status: " FontWeight="Bold" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding RecipeStatus}" FontSize="16" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="#57606f"/>
                    
                    <Button Content="Start Recipe" Command="{Binding StartRecipeCommand}" Background="#20bf6b" Foreground="White" Padding="15,8" BorderThickness="0" Margin="0,0,10,0" FontWeight="Bold"/>
                    <Button Content="Stop" Command="{Binding StopRecipeCommand}" Background="#eb3b5a" Foreground="White" Padding="15,8" BorderThickness="0" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Camera Feeds -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding CameraFeeds}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="4"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#dfe4ea" BorderThickness="1" CornerRadius="4" Margin="5" Background="#ffffff">
                        <Grid>
                            <!-- Placeholder for Image -->
                            <Rectangle Fill="#ced6e0" Margin="10"/>
                            <TextBlock Text="{Binding}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" Foreground="#2f3542" FontWeight="SemiBold"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
