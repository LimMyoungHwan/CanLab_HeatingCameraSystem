<UserControl x:Class="HeatingCameraSystem.Master.Views.CameraMappingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HeatingCameraSystem.Master.Views"
             xmlns:vm="clr-namespace:HeatingCameraSystem.Master.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1024" Background="#0e1321" Foreground="#dee2f7">

    <UserControl.Resources>
        <!-- Color resources -->
        <SolidColorBrush x:Key="BgSurface" Color="#0e1321"/>
        <SolidColorBrush x:Key="BgSurfaceContainer" Color="#1a1f2e"/>
        <SolidColorBrush x:Key="BgSurfaceContainerHigh" Color="#252a39"/>
        <SolidColorBrush x:Key="BgSurfaceContainerLow" Color="#161b2a"/>
        <SolidColorBrush x:Key="BgSurfaceContainerLowest" Color="#090e1c"/>
        <SolidColorBrush x:Key="BgSurfaceVariant" Color="#2f3444"/>
        <SolidColorBrush x:Key="Outline" Color="#859493"/>
        <SolidColorBrush x:Key="OutlineVariant" Color="#3b4949"/>
        <SolidColorBrush x:Key="Primary" Color="#47eaed"/>
        <SolidColorBrush x:Key="Secondary" Color="#4ae183"/>
        <SolidColorBrush x:Key="Error" Color="#ffb4ab"/>
        <SolidColorBrush x:Key="TextOnSurface" Color="#dee2f7"/>
        <SolidColorBrush x:Key="TextOnSurfaceVariant" Color="#bac9c9"/>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1a1f2e"/>
            <Setter Property="Foreground" Value="#dee2f7"/>
            <Setter Property="BorderBrush" Value="#3b4949"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#252a39"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SaveButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#00ced1"/>
            <Setter Property="Foreground" Value="#002020"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#00e5e8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Expander Dark Theme Style -->
        <Style TargetType="Expander">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <Grid Margin="0,4" HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Header Text bound to Expander's Tag or DataContext -->
                            <StackPanel Orientation="Horizontal" Grid.Column="0">
                                <TextBlock Text="{Binding Name}" Foreground="#dee2f7" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding TotalCount, StringFormat={} ({0})}" Foreground="#859493" FontSize="11" Margin="4,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Ellipse Grid.Column="1" Width="8" Height="8" Fill="#4ae183" VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Background="{StaticResource BgSurfaceContainerHigh}" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="0,0,0,1" Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Camera Position Mapping" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextOnSurface}" VerticalAlignment="Center"/>
                    <Border Background="{StaticResource BgSurfaceContainer}" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="1" CornerRadius="4" Padding="12,4" Margin="16,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ASSIGNED" Foreground="{StaticResource Outline}" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding AssignedRatioText}" Foreground="{StaticResource Primary}" FontSize="12" FontWeight="Bold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Clear All" Command="{Binding ClearAllCommand}" Style="{StaticResource HeaderButtonStyle}" Margin="0,0,12,0"/>
                    <Button Content="Save Mapping" Command="{Binding SaveMappingCommand}" Style="{StaticResource SaveButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Workspace -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <!-- 30% Available Cameras -->
                <ColumnDefinition Width="7*"/>
                <!-- 70% Position Grid -->
            </Grid.ColumnDefinitions>

            <!-- Left Sidebar (Available Cameras) -->
            <Border Grid.Column="0" Background="{StaticResource BgSurfaceContainer}" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Sidebar Header -->
                    <Border Grid.Row="0" Background="{StaticResource BgSurfaceContainerHigh}" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="0,0,0,1" Padding="16,12">
                        <StackPanel>
                            <TextBlock Text="Available Cameras" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextOnSurface}"/>
                            <TextBlock Text="Source Management" FontSize="10" Foreground="{StaticResource Outline}"/>
                        </StackPanel>
                    </Border>

                    <!-- Scrollable Camera Groups -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding AvailableAgents}" Margin="12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource BgSurfaceContainerLow}" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="1" CornerRadius="4" Margin="0,0,0,8" Padding="8">
                                        <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}" Header="{Binding}">
                                            <ItemsControl ItemsSource="{Binding Cameras}" Margin="0,8,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <!-- Camera Row -->
                                                        <Border Background="Transparent" Padding="8,6" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="0,0,0,1"
                                                                PreviewMouseLeftButtonDown="CameraItem_PreviewMouseLeftButtonDown"
                                                                MouseMove="CameraItem_MouseMove"
                                                                Cursor="Hand" ToolTip="Drag to assign, Drag indicator shows availability.">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <!-- Status Dot -->
                                                                <Ellipse Grid.Column="0" Width="6" Height="6" Margin="0,0,12,0" VerticalAlignment="Center">
                                                                    <Ellipse.Style>
                                                                        <Style TargetType="Ellipse">
                                                                            <Setter Property="Fill" Value="{StaticResource Secondary}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsAssigned}" Value="True">
                                                                                    <Setter Property="Fill" Value="{StaticResource Outline}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Ellipse.Style>
                                                                </Ellipse>

                                                                <!-- Camera ID -->
                                                                <TextBlock Grid.Column="1" Text="{Binding Id}" VerticalAlignment="Center" FontSize="13">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{StaticResource TextOnSurface}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsAssigned}" Value="True">
                                                                                    <Setter Property="Foreground" Value="{StaticResource Outline}"/>
                                                                                    <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                                                    <Setter Property="FontStyle" Value="Italic"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>

                                                                <!-- Lock/Drag Icon -->
                                                                <ContentControl Grid.Column="2" VerticalAlignment="Center">
                                                                    <ContentControl.Style>
                                                                        <Style TargetType="ContentControl">
                                                                            <Setter Property="Content">
                                                                                <Setter.Value>
                                                                                    <!-- Drag Indicator -->
                                                                                    <TextBlock Text="⋮⋮" Foreground="{StaticResource Outline}" FontSize="14" FontWeight="Bold"/>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsAssigned}" Value="True">
                                                                                    <Setter Property="Content">
                                                                                        <Setter.Value>
                                                                                            <TextBlock Text="🔒" Foreground="{StaticResource Outline}" FontSize="12"/>
                                                                                        </Setter.Value>
                                                                                    </Setter>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </ContentControl.Style>
                                                                </ContentControl>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Expander>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Sidebar Footer Status -->
                    <Border Grid.Row="2" Background="{StaticResource BgSurfaceContainerHigh}" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="0,1,0,0" Padding="16,12">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Sync Status" FontSize="11" Foreground="{StaticResource Outline}"/>
                                <TextBlock Text="{Binding SyncStatusText}" FontSize="11" Foreground="{StaticResource Secondary}" HorizontalAlignment="Right"/>
                            </Grid>
                            <ProgressBar Value="{Binding SyncProgress}" Height="4" Foreground="{StaticResource Primary}" Background="{StaticResource BgSurface}" BorderThickness="0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Right Workspace (Position Grid) -->
            <Border Grid.Column="1" Background="{StaticResource BgSurface}" Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid MaxWidth="1000" HorizontalAlignment="Center">
                        <!-- 8x8 Grid representing 64 positions -->
                        <ItemsControl ItemsSource="{Binding Slots}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="8" Rows="8" Margin="4"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Grid Slot Border -->
                                    <Border AllowDrop="True" DragEnter="Slot_DragEnter" Drop="Slot_Drop" PreviewMouseRightButtonDown="Slot_MouseRightButtonDown"
                                            Margin="6" BorderThickness="1" CornerRadius="4" Background="#161b2a" Height="90" Width="90" ToolTip="Right-click to unassign.">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="{StaticResource OutlineVariant}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasCamera}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{StaticResource Primary}"/>
                                                        <Setter Property="Background" Value="#252a39"/>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="{StaticResource Primary}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Grid Margin="6">
                                            <!-- Position Name (Top-left) -->
                                            <TextBlock Text="{Binding PositionId}" Foreground="{StaticResource Outline}" FontSize="10" HorizontalAlignment="Left" VerticalAlignment="Top"/>

                                            <!-- Content: Either Active Camera or empty slot indicator -->
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasCamera}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <Ellipse Width="6" Height="6" Fill="{StaticResource Secondary}" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding CameraId}" Foreground="{StaticResource TextOnSurface}" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
                                            </StackPanel>

                                            <!-- Empty Indicator -->
                                            <TextBlock Text="—" Foreground="{StaticResource OutlineVariant}" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasCamera}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
