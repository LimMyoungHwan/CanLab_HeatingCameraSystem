<UserControl x:Class="HeatingCameraSystem.Master.Views.DevicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="768" d:DesignWidth="1024" Background="#0e1321" Foreground="#dee2f7">

    <UserControl.Resources>
        <SolidColorBrush x:Key="BgSurface"              Color="#0e1321"/>
        <SolidColorBrush x:Key="BgSurfaceContainer"     Color="#1a1f2e"/>
        <SolidColorBrush x:Key="BgSurfaceContainerHigh" Color="#252a39"/>
        <SolidColorBrush x:Key="OutlineVariant"         Color="#3b4949"/>
        <SolidColorBrush x:Key="Primary"                Color="#47eaed"/>
        <SolidColorBrush x:Key="TextOnSurface"          Color="#dee2f7"/>
        <SolidColorBrush x:Key="Outline"                Color="#859493"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"   Value="#47eaed"/>
            <Setter Property="Foreground"   Value="#001f1f"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="16,8"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5ff5f8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#3b4949"/>
                                <Setter Property="Foreground" Value="#859493"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background"   Value="#1a1f2e"/>
            <Setter Property="Foreground"   Value="#dee2f7"/>
            <Setter Property="BorderBrush"  Value="#3b4949"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="16,8"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#859493"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Background="#252a39" BorderBrush="#3b4949" BorderThickness="0,0,0,1" Padding="24,14">
            <TextBlock Text="디바이스 관리 (Devices)" FontSize="20" FontWeight="Bold" Foreground="#dee2f7"/>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Device List -->
            <DataGrid Grid.Column="0" ItemsSource="{Binding Devices}"
                      SelectedItem="{Binding SelectedDevice}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      Background="#1a1f2e" Foreground="#dee2f7"
                      BorderThickness="0" GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#3b4949"
                      RowBackground="#1a1f2e" AlternatingRowBackground="#151b28"
                      HeadersVisibility="Column" CanUserReorderColumns="False"
                      SelectionMode="Single" Margin="8">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#252a39"/>
                        <Setter Property="Foreground" Value="#859493"/>
                        <Setter Property="Padding"    Value="8,6"/>
                        <Setter Property="FontSize"   Value="11"/>
                        <Setter Property="BorderBrush" Value="#3b4949"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Status" Width="60">
                        <DataGridTextColumn.Binding>
                            <MultiBinding StringFormat="{}{0}">
                                <Binding Path="IsRunning"/>
                            </MultiBinding>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="PCId"        Binding="{Binding PCId}" Width="100"/>
                    <DataGridTextColumn Header="Alias"       Binding="{Binding Alias}" Width="120"/>
                    <DataGridTextColumn Header="AgentId"     Binding="{Binding AgentId}" Width="140"/>
                    <DataGridTextColumn Header="HardwareId"  Binding="{Binding HardwareId}" Width="*"/>
                    <DataGridTextColumn Header="Approved"    Binding="{Binding IsApproved}" Width="70"/>
                    <DataGridTextColumn Header="CV Idx"      Binding="{Binding OpenCvIndex}" Width="55"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Right: Detail Panel -->
            <Border Grid.Column="1" Background="#1a1f2e" BorderBrush="#3b4949" BorderThickness="1,0,0,0" Padding="20,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Actions -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="액션" FontSize="14" FontWeight="Bold" Foreground="#dee2f7" Margin="0,0,0,12"/>

                        <TextBlock Text="Alias" Foreground="#859493" FontSize="11" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding SelectedDevice.Alias, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#252a39" Foreground="#dee2f7" BorderBrush="#3b4949"
                                 Padding="8,6" FontSize="13" Margin="0,0,0,12"/>

                        <WrapPanel Margin="0,0,0,8">
                            <Button Content="승인" Command="{Binding ApproveCommand}"
                                    Style="{StaticResource PrimaryButton}" Margin="0,0,8,4"/>
                            <Button Content="거부" Command="{Binding RejectCommand}"
                                    Style="{StaticResource SecondaryButton}" Margin="0,0,8,4"/>
                            <Button Content="이름 저장" Command="{Binding RenameCommand}"
                                    Style="{StaticResource SecondaryButton}" Margin="0,0,8,4"/>
                            <Button Content="로그 가져오기" Command="{Binding GetLogsCommand}"
                                    Style="{StaticResource SecondaryButton}" Margin="0,0,0,4"/>
                        </WrapPanel>
                    </StackPanel>

                    <!-- Alert -->
                    <Border Grid.Row="1" Background="#2a1520" CornerRadius="4" Padding="12,8" Margin="0,0,0,12"
                            Visibility="{Binding SelectedDevice.HasAlert, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                        <TextBlock Text="{Binding SelectedDevice.LastAlert}" Foreground="#ff6b6b"
                                   FontSize="12" TextWrapping="Wrap"/>
                    </Border>

                    <!-- Log Viewer -->
                    <Border Grid.Row="2" Background="#0e1321" BorderBrush="#3b4949" BorderThickness="1" CornerRadius="4">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBox Text="{Binding LogContent, Mode=OneWay}" IsReadOnly="True"
                                     Background="Transparent" Foreground="#a0b0a0" BorderThickness="0"
                                     FontFamily="Consolas" FontSize="11"
                                     TextWrapping="Wrap" Padding="8"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#252a39" Padding="16,8">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#47eaed" FontSize="12"/>
        </Border>
    </Grid>
</UserControl>
