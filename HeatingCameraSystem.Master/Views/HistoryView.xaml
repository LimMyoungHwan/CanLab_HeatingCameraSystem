<UserControl x:Class="HeatingCameraSystem.Master.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HeatingCameraSystem.Master.Views"
             xmlns:vm="clr-namespace:HeatingCameraSystem.Master.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1024" Background="#0e1321" Foreground="#dee2f7">

    <UserControl.Resources>
        <!-- Color resources -->
        <SolidColorBrush x:Key="BgSurface" Color="#0e1321"/>
        <SolidColorBrush x:Key="BgSurfaceContainer" Color="#1a1f2e"/>
        <SolidColorBrush x:Key="BgSurfaceContainerHigh" Color="#252a39"/>
        <SolidColorBrush x:Key="BgSurfaceContainerLow" Color="#161b2a"/>
        <SolidColorBrush x:Key="BgSurfaceContainerLowest" Color="#090e1c"/>
        <SolidColorBrush x:Key="BgSurfaceVariant" Color="#2f3444"/>
        <SolidColorBrush x:Key="Outline" Color="#859493"/>
        <SolidColorBrush x:Key="OutlineVariant" Color="#3b4949"/>
        <SolidColorBrush x:Key="Primary" Color="#47eaed"/>
        <SolidColorBrush x:Key="Secondary" Color="#4ae183"/>
        <SolidColorBrush x:Key="Error" Color="#ffb4ab"/>
        <SolidColorBrush x:Key="TextOnSurface" Color="#dee2f7"/>
        <SolidColorBrush x:Key="TextOnSurfaceVariant" Color="#bac9c9"/>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="SearchButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#47eaed"/>
            <Setter Property="Foreground" Value="#002020"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5af8fb"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StopButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#ffb4ab"/>
            <Setter Property="Foreground" Value="#690005"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#ffa193"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PageButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextOnSurfaceVariant}"/>
            <Setter Property="BorderBrush" Value="{StaticResource OutlineVariant}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource BgSurfaceContainerHigh}"/>
                                <Setter Property="Foreground" Value="{StaticResource Primary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Thermal Scale Gradient -->
        <LinearGradientBrush x:Key="ThermalGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FF0000" Offset="0"/>     <!-- Hot -->
            <GradientStop Color="#FFFF00" Offset="0.25"/>
            <GradientStop Color="#00FF00" Offset="0.5"/>
            <GradientStop Color="#00FFFF" Offset="0.75"/>
            <GradientStop Color="#0000FF" Offset="1"/>       <!-- Cold -->
        </LinearGradientBrush>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Filters -->
            <RowDefinition Height="*"/>    <!-- Data Table -->
            <RowDefinition Height="Auto"/> <!-- Footer Stats -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource BgSurfaceContainer}" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="0,0,0,1" Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Thermal Camera Monitor" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextOnSurface}"/>
                    <TextBlock Text="History Logs" FontSize="14" Foreground="{StaticResource Primary}" Margin="24,0,0,0" VerticalAlignment="Bottom" Padding="0,0,0,2"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel VerticalAlignment="Center" Margin="0,0,24,0" HorizontalAlignment="Right">
                        <TextBlock Text="64/64 connected" Foreground="{StaticResource Secondary}" FontSize="10" HorizontalAlignment="Right"/>
                        <TextBlock Text="LIVE FEED STABLE" Foreground="{StaticResource TextOnSurfaceVariant}" FontSize="12" FontWeight="SemiBold"/>
                    </StackPanel>
                    <Button Content="⚠️ EMERGENCY STOP" Command="{Binding EmergencyStopCommand}" Style="{StaticResource StopButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Filters -->
        <Border Grid.Row="1" Background="{StaticResource BgSurfaceContainerLow}" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="0,0,0,1" Padding="24,16">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                
                <!-- From Date -->
                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="From" Foreground="{StaticResource TextOnSurfaceVariant}" FontSize="11" Margin="0,0,0,6" FontWeight="SemiBold"/>
                    <DatePicker SelectedDate="{Binding FromDateTime, Mode=TwoWay}" Width="150" Background="{StaticResource BgSurfaceContainerLowest}" BorderBrush="{StaticResource OutlineVariant}" Foreground="{StaticResource TextOnSurface}"/>
                </StackPanel>

                <!-- To Date -->
                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="To" Foreground="{StaticResource TextOnSurfaceVariant}" FontSize="11" Margin="0,0,0,6" FontWeight="SemiBold"/>
                    <DatePicker SelectedDate="{Binding ToDateTime, Mode=TwoWay}" Width="150" Background="{StaticResource BgSurfaceContainerLowest}" BorderBrush="{StaticResource OutlineVariant}" Foreground="{StaticResource TextOnSurface}"/>
                </StackPanel>

                <!-- Camera Group -->
                <StackPanel Margin="0,0,24,0">
                    <TextBlock Text="Camera Filter" Foreground="{StaticResource TextOnSurfaceVariant}" FontSize="11" Margin="0,0,0,6" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding CameraGroups}" SelectedItem="{Binding SelectedCameraGroup, Mode=TwoWay}" Width="250" Background="{StaticResource BgSurfaceContainerLowest}" Foreground="{StaticResource TextOnSurface}" BorderBrush="{StaticResource OutlineVariant}"/>
                </StackPanel>

                <!-- Search Button -->
                <Button Content="SEARCH" Command="{Binding SearchCommand}" Style="{StaticResource SearchButtonStyle}" Height="30" Width="120" VerticalAlignment="Bottom"/>
            </StackPanel>
        </Border>

        <!-- Main Workspace (Data Table) -->
        <Border Grid.Row="2" Background="{StaticResource BgSurfaceContainerLowest}" Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ListView Table -->
            <Border Grid.Row="0" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="1" CornerRadius="8" Background="{StaticResource BgSurfaceContainerLow}" ClipToBounds="True">
                <Grid>
                    <!-- Header Grid -->
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource BgSurfaceContainerHigh}" Padding="16,10" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.5*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="TIMESTAMP" Foreground="{StaticResource Outline}" FontSize="10" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Text="CAMERA ID" Foreground="{StaticResource Outline}" FontSize="10" FontWeight="Bold"/>
                            <TextBlock Grid.Column="2" Text="TEMP (°C)" Foreground="{StaticResource Outline}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="3" Text="HUMIDITY (%RH)" Foreground="{StaticResource Outline}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="4" Text="THUMBNAIL" Foreground="{StaticResource Outline}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="5" Text="ACTION" Foreground="{StaticResource Outline}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Scrollable Logs list -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding LogItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource OutlineVariant}" BorderThickness="0,0,0,1" Padding="16,8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource BgSurfaceContainer}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="1.5*"/>
                                                <ColumnDefinition Width="1.5*"/>
                                                <ColumnDefinition Width="1.5*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="1.5*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Timestamp -->
                                            <TextBlock Grid.Column="0" Text="{Binding Timestamp, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Foreground="{StaticResource TextOnSurface}" FontSize="13" VerticalAlignment="Center"/>

                                            <!-- Camera ID -->
                                            <TextBlock Grid.Column="1" Text="{Binding CameraId}" Foreground="{StaticResource TextOnSurface}" FontSize="13" VerticalAlignment="Center"/>

                                            <!-- Temp -->
                                            <TextBlock Grid.Column="2" Text="{Binding Temperature, StringFormat={}{0:F1}}" Foreground="{StaticResource Primary}" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" FontWeight="Bold"/>

                                            <!-- Humidity -->
                                            <TextBlock Grid.Column="3" Text="{Binding Humidity, StringFormat={}{0:F1}}" Foreground="{StaticResource TextOnSurfaceVariant}" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                            <!-- Thumbnail -->
                                            <Border Grid.Column="4" CornerRadius="4" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="1" Width="64" Height="40" Background="{StaticResource BgSurfaceContainerHighest}" ClipToBounds="True" HorizontalAlignment="Center">
                                                <Image Source="{Binding ThumbnailUrl}" Stretch="UniformToFill"/>
                                            </Border>

                                            <!-- Action Button -->
                                            <Button Grid.Column="5" Content="Open ↗" Command="{Binding DataContext.OpenDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"
                                                    Background="Transparent" BorderThickness="0" Foreground="{StaticResource Outline}" Padding="8,4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource Primary}"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Pagination Row -->
            <Grid Grid.Row="1" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding ShowingRecordsText}" Foreground="{StaticResource TextOnSurfaceVariant}" FontSize="12" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="«" Command="{Binding MovePageCommand}" CommandParameter="first" Style="{StaticResource PageButtonStyle}"/>
                    <Button Content="‹" Command="{Binding MovePageCommand}" CommandParameter="prev" Style="{StaticResource PageButtonStyle}"/>
                    
                    <TextBlock Text="{Binding CurrentPage}" Foreground="{StaticResource Primary}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="12,0"/>
                    <TextBlock Text="of" Foreground="{StaticResource TextOnSurfaceVariant}" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding TotalPages}" Foreground="{StaticResource TextOnSurface}" FontSize="13" VerticalAlignment="Center" Margin="0,0,12,0"/>

                    <Button Content="›" Command="{Binding MovePageCommand}" CommandParameter="next" Style="{StaticResource PageButtonStyle}"/>
                    <Button Content="»" Command="{Binding MovePageCommand}" CommandParameter="last" Style="{StaticResource PageButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>

        <!-- Footer Stats Bar -->
        <Border Grid.Row="3" Background="{StaticResource BgSurfaceContainerLow}" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="0,1,0,0" Padding="24,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <!-- Status Indicator Dot -->
                    <Ellipse Width="8" Height="8" Fill="{StaticResource Secondary}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding SystemStatusText}" Foreground="{StaticResource TextOnSurfaceVariant}" FontSize="11" VerticalAlignment="Center" Margin="0,0,24,0"/>
                    <TextBlock Text="{Binding DbLatencyText}" Foreground="{StaticResource TextOnSurfaceVariant}" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding VersionText}" Foreground="{StaticResource Outline}" FontSize="10" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Detail Modal Overlay (Grid Overlay) -->
        <Grid Grid.Row="0" Grid.RowSpan="4" Background="#CC000000" Visibility="{Binding IsModalOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="{StaticResource BgSurfaceContainerHigh}" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="1" CornerRadius="8" Width="700" Height="500" HorizontalAlignment="Center" VerticalAlignment="Center" Effect="{DynamicResource DropShadowEffect}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/> <!-- Enlarged Image -->
                        <RowDefinition Height="Auto"/> <!-- Details Bar -->
                    </Grid.RowDefinitions>

                    <!-- Close Button -->
                    <Button Content="✕" Command="{Binding CloseDetailCommand}" Width="32" Height="32" Background="#80090e1c" Foreground="White" BorderThickness="0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="16" Panel.ZIndex="10">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="16">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Visual scale bar (Thermal scale indicator) Left Aligned on image -->
                    <Grid Panel.ZIndex="5" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="24,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="180"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="70°" Foreground="White" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <Border Grid.Row="1" Width="8" Background="{StaticResource ThermalGradient}" CornerRadius="4" BorderBrush="#80ffffff" BorderThickness="1"/>
                        <TextBlock Grid.Row="2" Text="10°" Foreground="White" FontSize="9" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </Grid>

                    <!-- Large Image -->
                    <Border Grid.Row="0" Background="{StaticResource BgSurfaceContainerLowest}" CornerRadius="8,8,0,0" ClipToBounds="True">
                        <Image Source="{Binding SelectedLog.ThumbnailUrl}" Stretch="Uniform"/>
                    </Border>

                    <!-- Details Bar -->
                    <Border Grid.Row="1" Background="{StaticResource BgSurfaceContainerLowest}" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="0,1,0,0" Padding="20" CornerRadius="0,0,8,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Camera Source -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,24,0">
                                <TextBlock Text="CAMERA SOURCE" Foreground="{StaticResource Outline}" FontSize="9" FontWeight="Bold"/>
                                <TextBlock Text="{Binding SelectedLog.CameraId}" Foreground="{StaticResource TextOnSurface}" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- Vertical Line divider -->
                            <Border Grid.Column="1" Background="{StaticResource OutlineVariant}" Width="1" Height="30" Margin="0,0,24,0" VerticalAlignment="Center"/>

                            <!-- Timestamp -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="TIMESTAMP" Foreground="{StaticResource Outline}" FontSize="9" FontWeight="Bold"/>
                                <TextBlock Text="{Binding SelectedLog.Timestamp, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Foreground="{StaticResource TextOnSurface}" FontSize="14" Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- Temperature / Humidity -->
                            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                <StackPanel Margin="0,0,16,0" VerticalAlignment="Center">
                                    <TextBlock Text="TEMPERATURE" Foreground="{StaticResource Outline}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Right"/>
                                    <TextBlock Text="{Binding SelectedLog.Temperature, StringFormat={}{0:F1}°C}" Foreground="{StaticResource Primary}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="HUMIDITY" Foreground="{StaticResource Outline}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Right"/>
                                    <TextBlock Text="{Binding SelectedLog.Humidity, StringFormat={}{0:F1}%RH}" Foreground="{StaticResource TextOnSurfaceVariant}" FontSize="18" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
