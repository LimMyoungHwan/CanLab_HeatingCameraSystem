<UserControl x:Class="HeatingCameraSystem.Master.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="768" d:DesignWidth="1024" Background="#0e1321" Foreground="#dee2f7">

    <UserControl.Resources>
        <SolidColorBrush x:Key="BgSurface"              Color="#0e1321"/>
        <SolidColorBrush x:Key="BgSurfaceContainer"     Color="#1a1f2e"/>
        <SolidColorBrush x:Key="BgSurfaceContainerHigh" Color="#252a39"/>
        <SolidColorBrush x:Key="OutlineVariant"         Color="#3b4949"/>
        <SolidColorBrush x:Key="Primary"                Color="#47eaed"/>
        <SolidColorBrush x:Key="TextOnSurface"          Color="#dee2f7"/>
        <SolidColorBrush x:Key="Outline"                Color="#859493"/>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#859493"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="Margin"      Value="0,0,0,4"/>
        </Style>

        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Background"       Value="#1a1f2e"/>
            <Setter Property="Foreground"       Value="#dee2f7"/>
            <Setter Property="BorderBrush"      Value="#3b4949"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="8,6"/>
            <Setter Property="FontSize"         Value="13"/>
        </Style>

        <Style x:Key="FieldCombo" TargetType="ComboBox">
            <Setter Property="Background"       Value="#1a1f2e"/>
            <Setter Property="Foreground"       Value="#dee2f7"/>
            <Setter Property="BorderBrush"      Value="#3b4949"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="8,6"/>
            <Setter Property="FontSize"         Value="13"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"   Value="#47eaed"/>
            <Setter Property="Foreground"   Value="#001f1f"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="24,10"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5ff5f8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#3b4949"/>
                                <Setter Property="Foreground" Value="#859493"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Background="#252a39" BorderBrush="#3b4949" BorderThickness="0,0,0,1" Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="카메라 시리얼 설정" FontSize="20" FontWeight="Bold"
                           Foreground="#dee2f7" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="+ 카메라 추가"
                        Command="{Binding AddCameraCommand}"
                        Background="#1a1f2e" Foreground="#dee2f7"
                        BorderBrush="#3b4949" BorderThickness="1"
                        Padding="16,8" FontSize="13"/>
            </Grid>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Camera List -->
            <Border Background="#1a1f2e" BorderBrush="#3b4949" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#252a39" BorderBrush="#3b4949"
                            BorderThickness="0,0,0,1" Padding="16,12">
                        <TextBlock Text="카메라 목록" FontSize="13" FontWeight="Bold" Foreground="#dee2f7"/>
                    </Border>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding CameraSettings}"
                             SelectedItem="{Binding SelectedSettings}"
                             Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4,2">
                                    <TextBlock Text="{Binding CameraIndex, StringFormat='Camera \{0\}'}"
                                               FontWeight="SemiBold" FontSize="13" Foreground="#dee2f7"/>
                                    <TextBlock Text="{Binding PortName}" FontSize="11" Foreground="#859493"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background"       Value="Transparent"/>
                                <Setter Property="Foreground"       Value="#dee2f7"/>
                                <Setter Property="Padding"          Value="12,8"/>
                                <Setter Property="BorderThickness"  Value="0,0,0,1"/>
                                <Setter Property="BorderBrush"      Value="#3b4949"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#252a39"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Right: Settings Form -->
            <Grid Grid.Column="1">

                <!-- Empty state -->
                <TextBlock Text="왼쪽에서 카메라를 선택하세요."
                           Foreground="#859493" FontSize="14"
                           HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettings}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Form -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="40,32" MaxWidth="460" HorizontalAlignment="Left">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSettings}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Text="{Binding SelectedSettings.CameraIndex, StringFormat='Camera \{0\} 설정'}"
                                   FontSize="18" FontWeight="Bold" Foreground="#dee2f7" Margin="0,0,0,28"/>

                        <!-- Port Name -->
                        <TextBlock Text="Port Name" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding SelectedSettings.PortName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldBox}" Margin="0,0,0,18"/>

                        <!-- Baud Rate / Data Bits -->
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Baud Rate" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding SelectedSettings.BaudRate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FieldBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Data Bits" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding SelectedSettings.DataBits, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FieldBox}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Parity / Stop Bits -->
                        <Grid Margin="0,0,0,36">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Parity" Style="{StaticResource FieldLabel}"/>
                                <ComboBox SelectedValue="{Binding SelectedSettings.Parity, Mode=TwoWay}"
                                          SelectedValuePath="Content"
                                          Style="{StaticResource FieldCombo}">
                                    <ComboBoxItem Content="None"/>
                                    <ComboBoxItem Content="Odd"/>
                                    <ComboBoxItem Content="Even"/>
                                    <ComboBoxItem Content="Mark"/>
                                    <ComboBoxItem Content="Space"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Stop Bits" Style="{StaticResource FieldLabel}"/>
                                <ComboBox SelectedValue="{Binding SelectedSettings.StopBits, Mode=TwoWay}"
                                          SelectedValuePath="Content"
                                          Style="{StaticResource FieldCombo}">
                                    <ComboBoxItem Content="One"/>
                                    <ComboBoxItem Content="OnePointFive"/>
                                    <ComboBoxItem Content="Two"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <!-- Send Button + Status -->
                        <StackPanel Orientation="Horizontal">
                            <Button Content="저장 &amp; 전송"
                                    Command="{Binding SaveAndSendCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,20,0"/>
                            <TextBlock Text="{Binding StatusMessage}"
                                       Foreground="#47eaed" FontSize="13"
                                       VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
